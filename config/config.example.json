{
  "agents": {
    "defaults": {
      "workspace": "~/.lele/workspace",
      "restrict_to_workspace": true,
      "model": "glm-4.7",
      "max_tokens": 8192,
      "temperature": 0.7,
      "max_tool_iterations": 20
    }
  },
  "session": {
    "ephemeral": true,
    "ephemeral_threshold": 560
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "token": "{{ENV_TELEGRAM_BOT_TOKEN}}",
      "proxy": "",
      "allow_from": [
        "{{ENV_TELEGRAM_USER_ID}}"
      ]
    },
    "discord": {
      "enabled": false,
      "token": "{{ENV_DISCORD_BOT_TOKEN}}",
      "allow_from": []
    },
    "maixcam": {
      "enabled": false,
      "host": "0.0.0.0",
      "port": 18790,
      "allow_from": []
    },
    "whatsapp": {
      "enabled": false,
      "bridge_url": "ws://localhost:3001",
      "allow_from": []
    },
    "feishu": {
      "enabled": false,
      "app_id": "{{ENV_FEISHU_APP_ID}}",
      "app_secret": "{{ENV_FEISHU_APP_SECRET}}",
      "encrypt_key": "{{ENV_FEISHU_ENCRYPT_KEY:}}",
      "verification_token": "{{ENV_FEISHU_VERIFICATION_TOKEN:}}",
      "allow_from": []
    },
    "dingtalk": {
      "enabled": false,
      "client_id": "{{ENV_DINGTALK_CLIENT_ID}}",
      "client_secret": "{{ENV_DINGTALK_CLIENT_SECRET}}",
      "allow_from": []
    },
    "slack": {
      "enabled": false,
      "bot_token": "{{ENV_SLACK_BOT_TOKEN}}",
      "app_token": "{{ENV_SLACK_APP_TOKEN}}",
      "allow_from": []
    },
    "line": {
      "enabled": false,
      "channel_secret": "{{ENV_LINE_CHANNEL_SECRET}}",
      "channel_access_token": "{{ENV_LINE_CHANNEL_ACCESS_TOKEN}}",
      "webhook_host": "0.0.0.0",
      "webhook_port": 18791,
      "webhook_path": "/webhook/line",
      "allow_from": []
    },
    "onebot": {
      "enabled": false,
      "ws_url": "ws://127.0.0.1:3001",
      "access_token": "{{ENV_ONEBOT_ACCESS_TOKEN:}}",
      "reconnect_interval": 5,
      "group_trigger_prefix": [],
      "allow_from": []
    }
  },
  "providers": {
    "anthropic": {
      "type": "anthropic",
      "api_key": "{{ENV_ANTHROPIC_API_KEY}}",
      "api_base": "{{ENV_ANTHROPIC_API_BASE:}}",
      "models": {
        "claude-sonnet": {
          "model": "claude-sonnet-4-5",
          "vision": true
        }
      }
    },
    "openai": {
      "type": "openai",
      "api_key": "{{ENV_OPENAI_API_KEY}}",
      "api_base": "{{ENV_OPENAI_API_BASE:}}",
      "web_search": true
    },
    "my-openai-compatible": {
      "type": "openai",
      "api_key": "{{ENV_MY_OPENAI_API_KEY:sk-xxx}}",
      "api_base": "{{ENV_MY_OPENAI_API_BASE:https://example.com/v1}}",
      "models": {
        "fast": {
          "model": "gpt-4o-mini",
          "vision": true,
          "temperature": 0.7
        },
        "o4-mini": {
          "model": "o4-mini",
          "context_window": 200000,
          "max_tokens": 100000,
          "temperature": 1.0,
          "reasoning": {
            "effort": "medium",
            "summary": "auto"
          }
        },
        "o3-mini": {
          "model": "o3-mini",
          "context_window": 200000,
          "max_tokens": 100000,
          "temperature": 1.0,
          "reasoning": {
            "effort": "high"
          }
        },
        "qwen3-thinking": {
          "model": "qwen3.5-397b-a17b-thinking",
          "context_window": 128000,
          "temperature": 0.8,
          "reasoning": {
            "effort": "high"
          }
        }
      }
    },
    "openrouter": {
      "type": "openrouter",
      "api_key": "{{ENV_OPENROUTER_API_KEY}}",
      "api_base": "{{ENV_OPENROUTER_API_BASE:}}"
    },
    "groq": {
      "type": "groq",
      "api_key": "{{ENV_GROQ_API_KEY}}",
      "api_base": "{{ENV_GROQ_API_BASE:}}"
    },
    "zhipu": {
      "type": "zhipu",
      "api_key": "{{ENV_ZHIPU_API_KEY}}",
      "api_base": "{{ENV_ZHIPU_API_BASE:}}"
    },
    "gemini": {
      "type": "gemini",
      "api_key": "{{ENV_GEMINI_API_KEY}}",
      "api_base": "{{ENV_GEMINI_API_BASE:}}"
    },
    "vllm": {
      "type": "vllm",
      "api_key": "{{ENV_VLLM_API_KEY:}}",
      "api_base": "{{ENV_VLLM_API_BASE:}}"
    },
    "nvidia": {
      "type": "nvidia",
      "api_key": "{{ENV_NVIDIA_API_KEY}}",
      "api_base": "{{ENV_NVIDIA_API_BASE:}}",
      "proxy": "{{ENV_NVIDIA_PROXY:http://127.0.0.1:7890}}"
    },
    "moonshot": {
      "type": "moonshot",
      "api_key": "{{ENV_MOONSHOT_API_KEY}}",
      "api_base": "{{ENV_MOONSHOT_API_BASE:}}"
    },
    "ollama": {
      "type": "ollama",
      "api_key": "{{ENV_OLLAMA_API_KEY:}}",
      "api_base": "{{ENV_OLLAMA_API_BASE:http://localhost:11434/v1}}"
    }
  },
  "tools": {
    "web": {
      "brave": {
        "enabled": false,
        "api_key": "{{ENV_BRAVE_API_KEY}}",
        "max_results": 5
      },
      "perplexity": {
        "enabled": false,
        "api_key": "{{ENV_PERPLEXITY_API_KEY}}",
        "max_results": 5
      }
    },
    "cron": {
      "exec_timeout_minutes": 5
    }
  },
  "heartbeat": {
    "enabled": true,
    "interval": 30
  },
  "devices": {
    "enabled": false,
    "monitor_usb": true
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790
  }
}
